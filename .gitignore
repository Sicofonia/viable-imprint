.env
config.yaml
CLAUDE.local.md

# Personal Claude Code overrides (permission mode, machine-specific allow
# rules) — .claude/settings.json (team-wide) is still committed.
.claude/settings.local.json
__pycache__/
*.pyc
*.pyo
.venv/
venv/
books/

# Live task prompts are personal editorial content — only the reference
# examples in prompts/examples/<system>/ are committed. Prompts live one
# folder per VSM system (prompts/s1b/, prompts/s1d/, ...); this pattern only
# matches that one level, so prompts/examples/<system>/ stays tracked.
/prompts/*/*_task.txt
# Exception: System 5's real prompt is substantively the same content already
# public in docs/vsm.md, so gitignoring it wouldn't protect anything — see
# docs/adr/006-system-5-policy-agent.md, point 7.
!/prompts/s5/policy_evaluation_task.txt

# Book design templates and their style mapping are specific to one imprint —
# only the .example.yaml reference ships with the project.
/templates/*.odt
/templates/format_styles.yaml
/templates/marketing_metadata.yaml

# System 4's scanned intelligence output and watchlist are personal/business-
# sensitive — same treatment as books/. Only sources.example.yaml is committed.
/intelligence/
/systems/s4/sources.yaml

# System 5's candidates-under-evaluation folder — same treatment as books/
# and intelligence/: personal/business-sensitive working data, not committed.
# See docs/adr/006-system-5-policy-agent.md.
/candidates/

# System 5's homeostat dashboard folder — same treatment. See
# docs/adr/007-system5-homeostat-dashboard.md.
/homeostat/

# System 1D's monthly newsletter folder — same treatment. See
# docs/adr/008-system1d-newsletter.md.
/newsletter/
