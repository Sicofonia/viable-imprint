.env
config.yaml
CLAUDE.local.md

# Personal Claude Code overrides (permission mode, machine-specific allow
# rules) — .claude/settings.json (team-wide) is still committed.
.claude/settings.local.json
__pycache__/
*.pyc
*.pyo
.venv/
venv/
books/

# Live task prompts are personal editorial content — only the reference
# examples in prompts/examples/<system>/ are committed. Prompts live one
# folder per VSM system (prompts/s1b/, prompts/s1d/, ...); this pattern only
# matches that one level, so prompts/examples/<system>/ stays tracked.
/prompts/*/*_task.txt

# Book design templates and their style mapping are specific to one imprint —
# only the .example.yaml reference ships with the project.
/templates/*.odt
/templates/format_styles.yaml
/templates/marketing_metadata.yaml

# System 4's scanned intelligence output and watchlist are personal/business-
# sensitive — same treatment as books/. Only sources.example.yaml is committed.
/intelligence/
/systems/s4/sources.yaml
